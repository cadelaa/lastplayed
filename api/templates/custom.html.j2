<svg 
    viewBox="0 0 {{ width }} {{ height }}" 
    preserveAspectRatio="xMidYMid meet" 
    style="width: 100%; height: auto; display: block; max-width: {{ width }}px;"
    xmlns="http://www.w3.org/2000/svg" 
    xmlns:xlink="http://www.w3.org/1999/xlink">

    <style>
        .bar {
            opacity: 1;
            transform-box: fill-box;
            transform-origin: center bottom;
            animation-name: pulse, barcolor;
            animation-iteration-count: infinite, infinite;
            animation-direction: alternate, normal;
            animation-timing-function: ease-out, linear;
        }

        @keyframes pulse {
            0%   { transform: scaleY(0.20); }
            100% { transform: scaleY(1); }
        }

        {{ bar_css | safe }}
    </style>

    <foreignObject width="{{ width }}" height="{{ height }}" x="0" y="0">
        <div xmlns="http://www.w3.org/1999/xhtml" class="container">
            <style>
                :root { --beat-duration: {{ beat_duration_ms }}ms; }
                * { box-sizing: border-box; margin: 0; padding: 0; }
                div { font-family: 'Courier New', Courier, monospace; }

                .container {
                    position: relative;
                    width: 100%;
                    height: 100%;
                    background-color: #0d1117;
                    border: 2px solid #3d444d;
                    border-radius: 4px;
                    padding: 12px;
                    overflow: hidden;
                }

                .header {
                    position: relative;
                    z-index: 2;
                    font-size: 9px;
                    color: #888888;
                    letter-spacing: 2px;
                    margin-bottom: 5px;
                    text-transform: uppercase;
                    font-family: 'Courier New', Courier, monospace;
                }

                .main {
                    position: relative;
                    z-index: 1;
                    display: flex;
                    align-items: center;
                    height: 100%;
                    gap: 12px;
                }
                
                .art {
                    flex-shrink: 0;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }

                .cover {
                    width: {{ album_size }}px;
                    height: {{ album_size }}px;
                    border-radius: 0px;
                    object-fit: cover;
                    filter: grayscale(100%) contrast(1.1);
                    border: 2px solid #3d444d;
                    opacity: 1;
                }

                .content {
                    flex: 1;
                    min-width: 0;
                    overflow: hidden;
                    display: flex;
                    flex-direction: column;
                    justify-content: center;
                }

                .status {
                    font-size: 9px;
                    color: #888888;
                    letter-spacing: 2px;
                    text-transform: uppercase;
                    margin-bottom: 4px;
                    font-family: 'Courier New', Courier, monospace;
                }

                .status::before {
                    content: '> ';
                    animation: blink 1.2s step-end infinite;
                }

                @keyframes blink {
                    0%, 100% { opacity: 1; }
                    50% { opacity: 0; }
                }

                .song, .artist { width: 100%; overflow: hidden; white-space: nowrap; }

                .song-text {
                    display: inline-block;
                    white-space: nowrap;
                    font-size: {{ song_font_size }}px;
                    font-weight: bold;
                    color: #ffffff;
                    font-family: 'Courier New', Courier, monospace;
                }

                .artist-text {
                    display: inline-block;
                    white-space: nowrap;
                    font-size: {{ artist_font_size }}px;
                    color: #aaaaaa;
                    font-family: 'Courier New', Courier, monospace;
                }

                .artist { margin-top: {{ artist_margin_top }}px; }

                .marquee-track {
                    display: flex;
                    white-space: nowrap;
                    width: max-content;
                    animation: marquee var(--scroll-duration) linear infinite;
                }

                .marquee-spacer { flex-shrink: 0; width: 50px; }

                @keyframes marquee {
                    0%   { transform: translateX(0); }
                    100% { transform: translateX(-33.333%); }
                }

                #bars-spacer {
                    height: {{ eq_spacer_height }}px;
                    margin-top: {{ eq_spacer_margin_top }}px;
                    width: 100%;
                }

                a { text-decoration: none; display: block; }
            </style>

            <div class="main">
                <a class="art" href="{{ song_uri }}" target="_blank">
                    <img src="data:image/png;base64,{{ image }}" class="cover" alt="Album art" />
                </a>

                <div class="content">
                    <div class="header">now playing</div>
                    <div class="status">track</div>

                    <a href="{{ song_uri }}" target="_blank">
                        <div class="song {% if song_marquee.enabled %}has-marquee{% endif %}">
                            {% if song_marquee.enabled %}
                            <span class="marquee-track" style="--scroll-duration: {{ song_marquee.duration }}s;">
                                <span class="song-text">{{ song_name }}</span>
                                <span class="marquee-spacer"></span>
                                <span class="song-text">{{ song_name }}</span>
                                <span class="marquee-spacer"></span>
                                <span class="song-text">{{ song_name }}</span>
                                <span class="marquee-spacer"></span>
                            </span>
                            {% else %}
                            <span class="song-text">{{ song_name }}</span>
                            {% endif %}
                        </div>
                    </a>

                    <a href="{{ artist_uri }}" target="_blank">
                        <div class="artist {% if artist_marquee.enabled %}has-marquee{% endif %}">
                            {% if artist_marquee.enabled %}
                            <span class="marquee-track" style="--scroll-duration: {{ artist_marquee.duration }}s;">
                                <span class="artist-text">{{ artist_name }}</span>
                                <span class="marquee-spacer"></span>
                                <span class="artist-text">{{ artist_name }}</span>
                                <span class="marquee-spacer"></span>
                                <span class="artist-text">{{ artist_name }}</span>
                                <span class="marquee-spacer"></span>
                            </span>
                            {% else %}
                            <span class="artist-text">{{ artist_name }}</span>
                            {% endif %}
                        </div>
                    </a>

                    <div id="bars-spacer"></div>
                </div>
            </div>
        </div>
    </foreignObject>

    <g id="bars" style="filter: brightness(0.6) grayscale(1);">
        {{ bar_svg | safe }}
    </g>
</svg>
